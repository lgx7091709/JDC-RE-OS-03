config global
	option anon_swap '0'
	option anon_mount '0'
	option auto_swap '1'
	option auto_mount '1'
	option delay_root '5'
	option check_fs '0'

# 1. overlay 系统分区 (必须放第一个)
config mount
	option target '/overlay'
	option device '/dev/mmcblk0p17'
	option enabled '1'
	option fstype 'ext4'
	option options 'rw,sync'
	option enabled_fsck '1'

# 2. samba 数据分区 (55G)
config mount
	option target '/mnt/samba'
	option device '/dev/mmcblk0p18'
	option enabled '1'
	option fstype 'ext4'
	option options 'rw,sync,noatime'
	option enabled_fsck '0'
# 3. 【最后一位】swap 交换分区 (必须放最后！)
config swap
	option device '/dev/mmcblk0p19'
	option enabled '1'
